# Firebase client SDK (public — safe to expose to the browser).
# Leave unset to run the app in stub mode (dev-only login, no real Firebase).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-only). Base64-encoded service account JSON.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Secret used to sign/verify the session cookie (jose HS256). Required for
# login to work, real or stubbed. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Which dealership tenant this deployment resolves to. Defaults to
# "ultima-cars" when unset.
NEXT_PUBLIC_DEFAULT_DEALERSHIP_ID=
